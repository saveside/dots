    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "´ùğ {capacity}%",
        "format-plugged": "´çĞ {capacity}%",
        "format-icons": [
            "´ëä ",
