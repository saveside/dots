    "custom/updates": {
      "interval": 120,
      "exec": "~/.config/waybar/modules/checkupdates",
      "on-click-right": "pkexec ~/.config/waybar/modules/update",
      "return-type": "json"
    },
    "custom/weather": {
        "format": "{}",
        "interval": 3600,
        "exec": "curl -s 'https://wttr.in/Trabzon?format=1'",
        "exec-if": "ping wttr.in -c1"
    },
    "custom/vpn": {
